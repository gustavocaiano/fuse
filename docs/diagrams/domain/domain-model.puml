@startuml


hide circle
hide methods
skinparam classAttributeIconSize 0
skinparam linetype ortho 

entity "User" as User {
  * id : bigint
  --
  name : string
  username : string
  email : string
  is_confirmed : bool
  has_email_authentication : bool
}

entity "Role" as Role {
  * id : bigint
  --
  name : string
  guard_name : string
  ad_group_name : string?
}

entity "Permission" as Permission {
  * id : bigint
  --
  name : string
  guard_name : string
  group : string
}

entity "Process" as Process {
  * id : bigint
  --
  number : string
  status : ProcessStatus
  crime_type : string?
  abilio_id : bigint?
  deadline_at : datetime?
}

entity "process_user" as ProcessUser {
  * process_id : bigint
  * user_id : bigint
  -- 
  start_at : datetime?
  end_at : datetime?
}

entity "Camera" as Camera {
  * id : bigint
  --
  process_id : bigint?
  slug : string
  name : string
  user : string
  password : string?
  path : string?
  ip_address : string
  rtsp_port : string
  rec : bool
  detection_enabled : bool
  detection_target_class : person|vehicle
  ptz_protocol : string?
  ptz_port : string?
}

entity "RecordingSegment" as RecordingSegment {
  * id : bigint
  --
  camera_id : bigint
  segment_uid : string
  relative_path : string
  started_at : datetime?
  duration_seconds : float
  size_bytes : int?
  status : queued | processing | detected | not_detected | failed
  target_class : person | vehicle?
  detector_job_id : string?
  detector_metadata : json?
  last_error : text?
}

entity "DetectionEvent" as DetectionEvent {
  * id : bigint
  --
  camera_id : bigint
  recording_segment_id : bigint
  event_type : string
  event_start_seconds : float?
  event_end_seconds : float?
  event_start_at : datetime?
  event_end_at : datetime?
  confidence : float?
  motion_score : float?
  metadata : json?
}

entity "DetectionObject" as DetectionObject {
  * id : bigint
  --
  detection_event_id : bigint
  label : string?
  confidence : float?
  track_id : string?
  bbox : json?
  bbox_samples : json?
  mask_ref : string?
  metadata : json?
}

User }o--o{ Role 
Role }o-down-o{ Permission 
User ||.down.o{ ProcessUser 
Process ||..o{ ProcessUser  
Process ||--o{ Camera 
Camera ||--o{ RecordingSegment 
Camera ||--o{ DetectionEvent 
RecordingSegment ||-left-o{ DetectionEvent 

DetectionEvent ||-up-o{ DetectionObject 

@enduml
